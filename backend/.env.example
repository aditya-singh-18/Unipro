# Server Configuration
PORT=5000
NODE_ENV=development

# Supabase Postgres Configuration
# Use the Transaction Pooler connection string from Supabase (recommended for Node apps)
# Example format:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=30m
SUPER_ADMIN_EMAIL=
CSRF_SECRET=change-me-csrf-secret
SUPABASE_STORAGE_URL=

# Email Configuration (Optional)
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASSWORD=
